# gentecBench devcontainer environment variables
# Copy this file to .env in this same folder:
#   cp .env.example .env

# Jupyter notebook token (set to empty string for no auth)
JUPYTER_TOKEN=gentecbench

# Windows Screenshots folder (WSL path to your OneDrive Screenshots folder)
# Find yours with: powershell.exe -Command "[Environment]::GetFolderPath('MyPictures')"
# Then convert to WSL path, e.g.:
#   C:\Users\You\OneDrive - Org\Pictures\Screenshots
#   becomes: /mnt/c/Users/You/OneDrive - Org/Pictures/Screenshots
WIN_SCREENSHOTS=
