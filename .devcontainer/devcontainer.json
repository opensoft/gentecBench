{
"name": "gentecBench - Bio Data Science & Genetics",
	"dockerComposeFile": "docker-compose.yml",
"service": "gentec_bench",
	"workspaceFolder": "/projects",
	
	// Mount host home directory directly for seamless config/SSH access
	"mounts": [
		// Current workspace (gentecBench)
		"source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
		// Host home directory mounted directly - gives access to SSH, configs, dotfiles
		"source=${localEnv:HOME},target=/home/${localEnv:USER},type=bind,consistency=cached"
	],
	
	// Container environment variables
	"containerEnv": {
		"USERNAME": "${localEnv:USER}",
		"USER_UID": "${localEnv:UID:-1000}",
		"USER_GID": "${localEnv:GID:-1000}",
		"DEBUG": "false"
	},
	
	// Configure tool-specific properties
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.vscode-pylance",
				"ms-toolsai.jupyter",
				"ms-toolsai.jupyter-keymap",
				"ms-toolsai.jupyter-renderers",
				"GitHub.copilot",
				"GitHub.copilot-chat",
				"ms-vscode.remote-containers",
				"eamodio.gitlens",
				"ms-vscode-remote.remote-ssh",
				"redhat.vscode-yaml"
			],
			"settings": {
				"terminal.integrated.defaultProfile.linux": "zsh",
"python.defaultInterpreterPath": "/opt/conda/envs/gentecbench/bin/python",
				"python.terminal.activateEnvironment": true,
				"jupyter.notebookFileRoot": "/workspace"
			}
		}
	},

	// Use 'forwardPorts' to make a list of ports inside the container available locally
	"forwardPorts": ["3000-3100", 8888, 8050, 5000],

	// Comment out to connect as root instead
	"remoteUser": "${localEnv:USER}"
}
